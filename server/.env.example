HOST=0.0.0.0
PORT=8787
HIC_EVENT_STORE=postgres
HIC_APP_STORE=postgres
POSTGRES_DB=head_in_clouds
POSTGRES_USER=hic_app
POSTGRES_PASSWORD=REPLACE_ME_LONG_RANDOM_VALUE
DATABASE_URL=postgres://hic_app:REPLACE_ME_LONG_RANDOM_VALUE@127.0.0.1:5432/head_in_clouds
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=5
HIC_ADMIN_TOKEN=REPLACE_ME_LONG_RANDOM_VALUE
HIC_REQUEST_LOGS=true
HIC_LEGAL_CONTACT_EMAIL=support@headintheclouds.app
HIC_NOTIFICATION_DISPATCH_ENABLED=false
HIC_PUSH_PROVIDER=apns
NOTIFICATION_DISPATCH_INTERVAL=60s
NOTIFICATION_DISPATCH_LIMIT=50
HIC_SMS_PROVIDER=disabled
HIC_SMS_MOCK_CODE=123456
# Set HIC_SMS_PROVIDER=tencent only after SMS signature/template approval.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
HIC_TENCENT_SMS_REGION=ap-guangzhou
HIC_TENCENT_SMS_SDK_APP_ID=
HIC_TENCENT_SMS_SIGN_NAME=
HIC_TENCENT_SMS_TEMPLATE_ID=
HIC_WECHAT_PROVIDER=disabled
HIC_WECHAT_APP_ID=
HIC_WECHAT_APP_SECRET=
HIC_IAP_PRODUCTS_JSON='{"hic.postcard.plus":{"plan":"postcard_plus","amount":12,"currency":"CNY"}}'
HEAD_IN_CLOUDS_API_BASE_URL=https://api.headinclouds.cn
HEAD_IN_CLOUDS_SHARE_BASE_URL=https://headinclouds.cn
APPLE_APP_ID_PREFIX=REPLACE_WITH_APPLE_TEAM_ID
IOS_BUNDLE_ID=com.headintheclouds.app
IOS_ASSOCIATED_DOMAIN_PATHS=/share/*,/wechat/*,/flight-spaces/*,/cards/*

# Tencent COS. Access keys must stay server-side only.
COS_BUCKET=headsincould-1305013589
COS_REGION=ap-shanghai
COS_PUBLIC_BASE_URL=https://headsincould-1305013589.cos.ap-shanghai.myqcloud.com
HIC_OBJECT_STORAGE_PROVIDER=disabled
HIC_BACKUP_OBJECT_PREFIX=backups/postgres
COS_SECRET_ID=
COS_SECRET_KEY=

# APNs is required before production same-flight remote push verification.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_FILE=
APNS_USE_SANDBOX=true
